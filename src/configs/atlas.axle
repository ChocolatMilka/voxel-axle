// configs::atlas — texture atlas geometry and the per-tile indices.
//
// The atlas is a vertical strip of square tiles. The first `blockTiles` tiles
// are block faces; any tiles above that are mob skins. Bump `atlasTiles` (and
// the embedded hex in bake_atlas.py) when you add mob textures, then flip
// `useMobTextures` on. The tl* indices MIRROR THE ORDER IN `bake_atlas.py`
// EXACTLY — keep them in sync.

const tilePx : i32 = 64;
const blockTiles : i32 = 81;
const atlasTiles : i32 = 94;
const useMobTextures : bool = true;
// Mip chain depth (64 → 32 → … → 1 = 7 levels). Distant faces sample a
// coarser, pre-averaged level so textures don't shimmer when moving.
const mipLevels : i32 = 7;

// ── Block tiles (0 .. blockTiles-1) ─────────────────────────
const tlGrassTop : i32 = 0;
const tlGrassSide : i32 = 1;
const tlDirt : i32 = 2;
const tlCoarseDirt : i32 = 3;
const tlPodzolTop : i32 = 4;
const tlPodzolSide : i32 = 5;
const tlMyceliumTop : i32 = 6;
const tlMyceliumSide : i32 = 7;
const tlSand : i32 = 8;
