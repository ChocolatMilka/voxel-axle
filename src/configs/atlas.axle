const tlWater : i32 = 57;
const tlCoalOre : i32 = 58;
const tlIronOre : i32 = 59;
const tlGoldOre : i32 = 60;
const tlDiamondOre : i32 = 61;
const tlRedstoneOre : i32 = 62;
const tlEmeraldOre : i32 = 63;
