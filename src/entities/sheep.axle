// Sheep — calm grazer. Uses the base wander AI.

use crate::entities::mob::Mob;
use crate::config;
use crate::config::{ MobKind };

class Sheep extends Mob {
    /** Create a sheep at (x, y, z). */
    constructor(x : f64, y : f64, z : f64) {
        super(x, y, z, MobKind::Sheep, config::mobSheepHp);
        this.speed = config::mobSheepSpeed;
        this.height = 1.2;
    }
}
