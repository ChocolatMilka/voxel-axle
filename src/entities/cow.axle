// Cow — big, slow grazer. Uses the base wander AI.

use crate::entities::mob::Mob;
use crate::config;
use crate::config::{ MobKind };

class Cow extends Mob {
    /** Create a cow at (x, y, z). */
    constructor(x : f64, y : f64, z : f64) {
        super(x, y, z, MobKind::Cow, config::mobCowHp);
        this.speed = config::mobCowSpeed;
        this.height = 1.4;
    }
}
