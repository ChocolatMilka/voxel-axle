// Plains — flat green grassland with sparse oaks. Grass surface + dirt filler
// are the base defaults, so only the tree parameters differ.

use crate::world::biomes::Biome;
use crate::config;
use crate::config::{ TreeKind };

class Plains extends Biome {
    /** Construct the plains biome. */
    constructor() {
        super();
        this.treeThresh = 0.992;
        this.treeKindId = TreeKind::Oak;
        this.treeHt = 4;
    }
}
