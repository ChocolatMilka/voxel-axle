// Cherry grove — mild hills of grass dotted with pink cherry blossoms.

use crate::world::biomes::Biome;
use crate::config;
use crate::config::{ TreeKind };

class CherryGrove extends Biome {
    /** Construct the cherry grove biome. */
    constructor() {
        super();
        this.treeThresh = 0.965;
        this.treeKindId = TreeKind::Cherry;
        this.treeHt = 5;
    }
    // Grass surface + dirt filler are the base defaults.
}
