// Desert — sand over sandstone, the odd cactus, no trees.

use crate::world::biomes::Biome;
use crate::config;

class Desert extends Biome {
    constructor() { super(); }
    fn surface(height : i32) : i32 { return config::bSand; }
    fn filler() : i32 { return config::bSandstone; }
    fn treeThreshold() : f64 { return 0.992; }
    fn treeKind() : i32 { return config::treeCactus; }
}
