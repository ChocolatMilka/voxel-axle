// Snowy — snow-covered ground with hardy spruces.

use crate::world::biomes::Biome;
use crate::config;

class Snowy extends Biome {
    constructor() { super(); }
    fn surface(height : i32) : i32 { return config::bSnow; }
    fn filler() : i32 { return config::bDirt; }
    fn treeThreshold() : f64 { return 0.984; }
    fn treeKind() : i32 { return config::treeSpruce; }
}
